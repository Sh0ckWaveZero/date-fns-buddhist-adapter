{
  "name": "@midseelee/date-fns-buddhist-adapter",
  "repository": "git@github.com:Sh0ckWaveZero/date-fns-buddhist-adapter.git",
  "version": "1.0.8",
  "description": "date-fns adapter with Buddhist years functionality",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "private": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "TZ=UTC jest",
    "test:watch": "TZ=UTC jest --watch",
    "test:coverage": "TZ=UTC jest --coverage",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "tsc --watch",
    "prepare": "husky install",
    "prepublishOnly": "bun run typecheck && bun run test && bun run build",
    "lint": "prettier --check \"**/*.{md,yml,json}\" && eslint .",
    "lint:fix": "prettier --write \"**/*.{md,yml,json}\" && eslint . --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "rebuild": "bun run clean && bun run build",
    "example:dev": "cd example && bun run dev",
    "example:install": "cd example && bun install",
    "example:build": "cd example && bun run build",
    "start": "bun src/index.ts"
  },
  "keywords": [
    "date",
    "date-fns",
    "date-io",
    "buddhist",
    "date-picker",
    "mui-x",
    "react"
  ],
  "author": "midseelee",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@date-io/date-fns": "3.2.1",
    "date-fns": "4.3.0"
  },
  "peerDependencies": {
    "@mui/material": "^9.0.1",
    "@mui/x-date-pickers": "^9.3.0",
    "react": "^19.2.6"
  },
  "overrides": {
    "@typescript-eslint/utils": "8.59.4"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tsconfig/node-lts": "24.0.0",
    "@types/jest": "30.0.0",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@typescript-eslint/eslint-plugin": "8.59.4",
    "@typescript-eslint/parser": "8.59.4",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jest": "29.15.2",
    "eslint-plugin-prettier": "5.5.5",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "prettier": "3.8.3",
    "ts-jest": "29.4.11",
    "ts-node": "10.9.2",
    "typescript": "6.0.3"
  }
}
